# Supabase project used by the running app (dev/prod).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase project used ONLY by the integration test suite (tests/integration).
# Use a disposable/dedicated Supabase project, never production. The service
# role key is required because the tests write directly to auth.users and to
# the server-side-only whitelist table, both of which bypass RLS. The anon
# key drives a real sign-in (password-based, as a stand-in for the Google
# OAuth handshake) to exercise the Custom Access Token hook's per-login
# whitelist revocation check.
SUPABASE_TEST_URL=
SUPABASE_TEST_ANON_KEY=
SUPABASE_TEST_SERVICE_ROLE_KEY=
